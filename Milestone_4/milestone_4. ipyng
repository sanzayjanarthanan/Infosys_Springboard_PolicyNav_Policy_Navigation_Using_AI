        "                new_confirmed = db_module.confirm_email_update(email)\n",
        "                if new_confirmed:\n",
        "                    st.session_state.token = generate_token(new_confirmed)\n",
        "                    st.session_state.email_change_step = 1\n",
        "                    st.success('✅ Email updated! Please re-login.')\n",
        "                    st.balloons()\n",
