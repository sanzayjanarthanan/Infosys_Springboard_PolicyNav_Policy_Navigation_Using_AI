        "        doc = nlp(text)\n",
        "        entities = [\n",
        "            (ent.text.strip(), ent.label_) for ent in doc.ents\n",
        "            if ent.label_ in ['ORG','GPE','LAW','PERSON'] and len(ent.text.strip()) > 2\n",
        "        ]\n",
        "\n",
        "        entities = list(dict.fromkeys(entities))[:15]\n",
        "\n",
        "        source_node = f\"Doc: {docs[i]['filename']}\"\n",
